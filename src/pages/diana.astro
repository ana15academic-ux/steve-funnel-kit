---
/**
 * Diana Payton — AI Cheatsheet Lead Magnet
 * Based on: src/pages/squeeze.astro (copied exactly)
 * URL: /diana
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Button from '@/components/ui/form/Button/Button.astro';

const benefits = [
  'AI Tools — Claude, ChatGPT, Gemini, Copilot',
  'Key Concepts — Agents, skills, routines, hooks',
  'Who to Follow — Top voices in AI for tech writing',
];
---

<BaseLayout
  title="Free AI Cheat Sheet for Tech Writers"
  description="The AI tools, concepts, people and steps every technical writer needs in 2026."
  noindex={true}
>
  <Fragment slot="head">
    <meta property="og:title" content="Free AI Cheat Sheet for Tech Writers" />
    <meta property="og:description" content="Tools, concepts, people to follow, and exactly how to prepare — all on one page. Free." />
    <meta property="og:site_name" content="Technical Writing Uncensored" />
    <meta property="og:url" content="https://diana-cheatsheet.pages.dev/diana" />
    <meta property="og:image" content="https://diana-cheatsheet.pages.dev/images/diana-og.png" />
    <meta property="og:type" content="website" />
    <link rel="canonical" href="https://diana-cheatsheet.pages.dev/diana" />
  </Fragment>
  <section class="sq-hero relative overflow-hidden">
    <div
      class="bg-grid-pattern pointer-events-none absolute inset-0 [mask-image:linear-gradient(to_bottom,white,transparent)] opacity-40"
      aria-hidden="true"
    />

    <div class="mx-auto max-w-6xl px-6 relative z-10 py-6 md:py-0">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-[var(--space-section-gap)]" style="align-items:stretch">

        {/* Left Column: Cover Image + Benefits */}
        <div class="hidden lg:block">
          <Badge variant="brand" pill>
            FREE 2026 CHEATSHEET
          </Badge>
          <img src="/images/logo.png" alt="Technical Writing Uncensored" class="max-h-96 w-auto block mt-3" loading="eager" />
          <div class="mt-[var(--space-heading-gap)]">
            <h3 class="text-base font-bold text-foreground">What's inside</h3>
            <ul class="mt-4 space-y-3">
              {benefits.map((item) => (
                <li class="flex gap-3 items-start text-foreground-secondary text-sm">
                  <Icon name="check-circle" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        {/* Right Column: Heading + Description + Form */}
        <div style="display:flex; flex-direction:column">
          <div style="margin-top:auto">
            <h1 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-foreground leading-tight">
              The AI Cheatsheet Every Technical Writer Needs Right Now!
            </h1>
            <p class="mt-2 text-base leading-relaxed text-foreground-muted">
              Tools, concepts, people to follow, and exactly how to prepare — all on one page. Free.
            </p>
            {/* Mobile image */}
            <div class="mt-4 lg:hidden">
              <div class="overflow-hidden rounded-lg">
                <img src="/images/logo.png" alt="Technical Writing Uncensored" class="w-full h-auto" loading="eager" />
              </div>
            </div>
            {/* Mobile benefits */}
            <ul class="mt-4 space-y-2 lg:hidden">
              {benefits.map((item) => (
                <li class="flex gap-2 items-start text-foreground-secondary text-sm">
                  <Icon name="check-circle" size="sm" class="text-brand-500 mt-0.5 shrink-0" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <form id="diana-form" class="mt-4 space-y-6" novalidate>
            <Input label="Full Name"            type="text"  name="name"     placeholder="Jane Smith"                       required />
            <Input label="Email Address"        type="email" name="email"    placeholder="jane@example.com"                 required autocomplete="email" />
            <Input label="LinkedIn Profile URL" type="url"   name="linkedin" placeholder="https://linkedin.com/in/yourname" required />
            <Button type="submit" variant="primary" size="lg" class="w-full">
              Send Me the Cheatsheet
            </Button>
          </form>
          <div id="diana-success" class="hidden mt-4 text-center font-bold" style="color:white;">
            🎉 You're in! Check your inbox.
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sq-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 32px;
    padding-bottom: 32px;
  }
</style>

<style is:global>
  /* Items 1–3: no header/footer, no white strip */
  body:has(.sq-hero) {
    background-color: #0B66C2;
  }
  body:has(.sq-hero) footer,
  body:has(.sq-hero) header {
    display: none !important;
  }

  /* Hero background */
  .sq-hero { background-color: #0B66C2 !important; }
  .sq-hero * { --background: #0B66C2; }

  /* Item 4: white text throughout the hero */
  .sq-hero .text-foreground,
  .sq-hero h1,
  .sq-hero h3 {
    color: white !important;
  }
  .sq-hero .text-foreground-muted,
  .sq-hero .text-foreground-secondary {
    color: rgba(255, 255, 255, 0.82) !important;
  }
  .sq-hero label {
    color: white !important;
  }

  /* Item 6: dark navy button */
  .sq-hero button[type="submit"] {
    background-color: #0d1b3e !important;
    color: white !important;
  }
  .sq-hero button[type="submit"]:hover {
    background-color: #000 !important;
  }
</style>

<script>
  const form = document.getElementById('diana-form') as HTMLFormElement | null;
  const success = document.getElementById('diana-success') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailEl = form.querySelector<HTMLInputElement>('[name="email"]');
    const nameEl = form.querySelector<HTMLInputElement>('[name="name"]');
    const linkedinEl = form.querySelector<HTMLInputElement>('[name="linkedin"]');
    if (!nameEl?.checkValidity()) { nameEl?.reportValidity(); return; }
    if (!emailEl?.checkValidity()) { emailEl?.reportValidity(); return; }
    if (!linkedinEl?.checkValidity()) { linkedinEl?.reportValidity(); return; }

    let errorEl = form.querySelector<HTMLElement>('#diana-error');
    if (errorEl) errorEl.remove();

    const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch('https://api.convertkit.com/v3/forms/9513960/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          api_key: 'Ht-Lkxf0WSVa2Be2Wwrflg',
          email: emailEl?.value ?? '',
          first_name: nameEl?.value ?? '',
        }),
      });

      if (!res.ok) throw new Error('Request failed');

      window.location.href = '/thank-you';
    } catch {
      const err = document.createElement('p');
      err.id = 'diana-error';
      err.style.cssText = 'color:#ef4444;margin-top:0.5rem;font-size:0.875rem;';
      err.textContent = 'Something went wrong. Please try again.';
      submitBtn?.insertAdjacentElement('afterend', err);
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
