    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="font-display text-xl md:text-2xl lg:text-3xl font-medium text-white leading-snug">
        Businesses are leaving money on the table managing HR across spreadsheets and WhatsApp. This fixes that.
      </p>
      <div class="mt-6 flex items-center justify-center gap-3">
        <div class="h-8 w-8 rounded-full purple-dot flex items-center justify-center shrink-0">
          <span class="text-white text-xs font-bold">L</span>
        </div>
        <p class="text-sm text-white/80">
          <span class="text-white font-semibold">Limendo mERP</span>&nbsp;&middot;&nbsp;Powered by Frappe HR
        </p>
      </div>
    </div>
  </section>

  {/* ================================================================
      EDITORIAL
      ================================================================ */}
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-4xl px-6">
      <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold tracking-tight text-[#0a0010] text-center mb-10 md:mb-14 leading-tight">
        Stop managing HR across five different tools
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <div class="space-y-5 text-base leading-relaxed text-[#444444]">
          <p>Imagine having every HR process — hiring, attendance, leave approvals, payroll, and performance reviews — running in a single system your whole team can access from anywhere.</p>
          <p>No more chasing managers for approvals over WhatsApp. No more manual payroll calculations in Excel. No more missing compliance deadlines because records were scattered across the wrong tools.</p>
        </div>
        <div class="space-y-5 text-base leading-relaxed text-[#444444]">
          <p>Limendo mERP powered by Frappe HR gives you a complete, organized HR operation — whether you're managing 10 employees or 500.</p>
          <p>It scales with you, keeps all your data in one place, and lets your HR team focus on people instead of paperwork.</p>
          <p class="font-bold text-[#0a0010]">Book a free demo and see how it works in your business.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ================================================================
      MODULES
      ================================================================ */}
  <section class="py-14 md:py-20">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-[#0a0010] text-center mb-10 md:mb-14">
        A glimpse at what's inside…
      </h2>

      <div class="modules-list">
        {modules.map(({ num, title, desc }) => (
          <div class="module-item py-6 first:pt-0 last:pb-0">
            <h3 class="font-display text-base md:text-lg font-bold text-[#0a0010] flex items-baseline gap-3">
              <span class="font-mono text-sm font-bold shrink-0 module-num">{num} —</span>
              <span>{title}</span>
            </h3>
            <p class="mt-1.5 text-sm text-[#555555] leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ================================================================
      BOTTOM CTA — purple band
      ================================================================ */}
  <section class="elm-cta py-10 md:py-14">
    <div class="mx-auto max-w-5xl px-6">
      <div class="flex flex-col lg:flex-row lg:items-center gap-6 lg:gap-16">
        <div class="lg:w-1/2">
          <h2 class="font-display text-xl md:text-2xl font-bold text-white leading-tight">
            See Limendo mERP in action — book your free demo
          </h2>
          <p class="mt-2 text-sm text-white/70 leading-relaxed">
            From hiring to payroll, we'll walk you through how Limendo mERP handles
            every part of your workforce — in about 30 minutes.
          </p>
        </div>
        <div class="lg:w-1/2">
          <div id="form-cta-wrap">
            <form id="lead-form-cta" class="space-y-3" novalidate>
              <input type="hidden" name="access_key" value="54963d31-2c10-4442-993a-5d5ff490291a" />
              <input type="hidden" name="subject" value="Limendo mERP — Demo Request (CTA)" />
              <input type="hidden" name="from_name" value="Limendo mERP" />
              <input type="checkbox" name="botcheck" style="display:none" aria-hidden="true" />
              <input type="text" name="name" placeholder="Full Name" required autocomplete="name" class="form-field form-field-cta" />
              <input type="tel" name="phone" placeholder="Phone Number" required autocomplete="tel" class="form-field form-field-cta" />
              <button type="submit" id="cta-btn" class="submit-btn">Book a Free Demo</button>
            </form>
            <p class="mt-2 text-xs text-white/40">
              We'll walk you through everything — no tech knowledge needed.
            </p>
          </div>
          <div id="success-cta" style="display:none" class="mt-3">
            <p class="text-base font-semibold lime-text">Thanks! We'll be in touch soon.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</LeadLayout>

<style>
  /* ── Limendo brand tokens (global) ── */
  :global(:root) {
    --l-bg-start: #3f195c;
    --l-bg-end:   #09000a;
    --l-purple:   #9b00f5;
    --l-lime:     #d3d802;
    --l-dark:     #0a0010;
  }

  /* Light page background */
  :global(html) {
    background: #f8f5ff;
  }
  :global(body) {
    background: transparent !important;
    font-family: 'Barlow Condensed', Arial, sans-serif;
  }

  /* Hide header and footer */
  :global(header),
  :global(footer) {
    display: none !important;
  }

  /* ── Hero ── */
  .elm-hero {
    padding-top: 3rem;
    padding-bottom: 2rem;
    background: transparent;
  }
  @media (min-width: 1024px) {
    .elm-hero {
      padding-top: 4rem;
      padding-bottom: 2.5rem;
    }
  }

  /* ── Label chip — purple on light ── */
  .label-chip {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--l-purple);
    border: 1px solid color-mix(in srgb, var(--l-purple) 40%, transparent);
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
  }

  /* ── Dashboard panel — dark gradient card ── */
  .dashboard-panel {
    background: linear-gradient(155deg, var(--l-bg-start) 0%, var(--l-bg-end) 70%);
    border-radius: 1rem;
    padding: 1rem;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--l-purple) 45%, transparent),
      0 0 32px color-mix(in srgb, var(--l-purple) 20%, transparent),
      0 8px 40px rgba(0, 0, 0, 0.45);
  }

  /* ── Check dot in hero benefits ── */
  .check-dot {
    background: var(--l-purple);
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    animation: bounce-subtle 2s ease-in-out infinite;
    opacity: 0.4;
  }
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(6px); }
  }

  /* ── Colored bands (quote + CTA) — keep dark ── */
  .elm-band,
  .elm-cta {
    background: linear-gradient(135deg, var(--l-bg-start) 0%, var(--l-dark) 100%);
    border-top: 1px solid color-mix(in srgb, var(--l-purple) 35%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--l-purple) 35%, transparent);
  }

  /* ── Band avatar dot ── */
  .purple-dot {
    background: var(--l-purple);
  }

  /* ── Module dividers — light mode ── */
  .module-item {
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }
  .module-item:first-child {
    border-top: none;
  }

  /* ── Lime accent text (success message, dark sections) ── */
  .lime-text {
    color: var(--l-lime);
  }

  /* ── Module number — purple on light background ── */
  .module-num {
    color: var(--l-purple);
  }

  /* ── Hero form fields — light mode ── */
  .form-field {
    width: 100%;
    padding: 0.75rem 1rem;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: 0.5rem;
    color: var(--l-dark);
    font-size: var(--text-sm);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    -webkit-appearance: none;
  }

  .form-field::placeholder {
    color: rgba(0, 0, 0, 0.35);
  }

  .form-field:focus {
    border-color: var(--l-purple);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--l-purple) 18%, transparent);
  }

  /* CTA band fields — dark glass (inside dark band) */
  .form-field-cta {
    background: rgba(255, 255, 255, 0.10);
    border-color: rgba(255, 255, 255, 0.22);
    color: white;
  }

  .form-field-cta::placeholder {
    color: rgba(255, 255, 255, 0.38);
  }

  /* ── Submit button ── */
  .submit-btn {
    width: 100%;
    padding: 0.85rem 1.5rem;
    background: var(--l-purple);
    color: white;
    font-size: var(--text-sm);
    font-weight: 700;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    letter-spacing: 0.01em;
  }

  .submit-btn:hover:not(:disabled) {
    background: #7a00c4;
  }

  .submit-btn:active:not(:disabled) {
    transform: scale(0.985);
  }

  .submit-btn:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }
</style>

<script>
  function setupForm(
    formId: string,
    wrapId: string,
    successId: string,
    btnId: string
  ) {
    const form    = document.getElementById(formId)    as HTMLFormElement    | null;
    const wrap    = document.getElementById(wrapId);
    const success = document.getElementById(successId);
    const btn     = document.getElementById(btnId)     as HTMLButtonElement  | null;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!btn) return;
      btn.disabled = true;
      btn.textContent = 'Sending…';

      const payload = Object.fromEntries(new FormData(form!).entries());

      try {
        const res  = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json();

        if (json.success) {
          if (wrap) wrap.style.display = 'none';
          if (success) success.style.display = 'block';
        } else {
          btn.disabled = false;
          btn.textContent = 'Book a Free Demo';
        }
      } catch {
        btn.disabled = false;
        btn.textContent = 'Book a Free Demo';
      }
    });
  }

  setupForm('lead-form-hero', 'form-hero-wrap', 'success-hero', 'hero-btn');
  setupForm('lead-form-cta',  'form-cta-wrap',  'success-cta',  'cta-btn');
</script>
