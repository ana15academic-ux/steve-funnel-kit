          </ul>

          {/* Mobile dashboard SVG */}
          <div class="mt-4 lg:hidden dashboard-panel" set:html={dashboardSvg} />

          <div class="mt-4 max-w-md">
            <div id="form-hero-wrap">
              <form id="lead-form-hero" class="space-y-3" novalidate>
                <input type="hidden" name="access_key" value="54963d31-2c10-4442-993a-5d5ff490291a" />
                <input type="hidden" name="subject" value="Limendo mERP — Demo Request" />
                <input type="hidden" name="from_name" value="Limendo mERP" />
                <input type="checkbox" name="botcheck" style="display:none" aria-hidden="true" />
                <input type="text" name="name" placeholder="Full Name" required autocomplete="name" class="form-field" />
