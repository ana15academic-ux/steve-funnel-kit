const benefits = [
  'Post jobs and auto-capture applicants from a branded portal',
  'Track attendance via biometric devices, RFID, or bulk upload',
  'Run payroll with automatic tax and multi-structure support',
];

const modules = [
  {
    num: '01',
    title: 'Recruitment & Job Portal',
    desc: 'Publish job openings to a self-serve portal and receive structured applicant records automatically — no inbox digging, no spreadsheets. Build recruitment plans, manage vacancies, and move candidates through your pipeline in one place.',
  },
  {
    num: '02',
    title: 'Attendance & Shift Management',
    desc: 'Mark attendance for individuals or entire teams in bulk, pull logs automatically from biometric or RFID devices, and generate monthly compliance reports. Track Present, Absent, Half Day, and On Leave statuses across every shift and department.',
  },
  {
    num: '03',
    title: 'Leave & Performance Tracking',
    desc: 'Automate leave requests, manager approvals, and balance tracking across Sick Leave, Casual Leave, Privilege Leave, and more. Define KRA-based appraisal templates and run structured self-appraisal and feedback cycles aligned to your company goals.',
  },
  {
    num: '04',
    title: 'Salary, Payroll & Tax',
    desc: 'Run multi-structure payrolls with automatic tax calculations, off-cycle payment support, and transparent salary breakdowns for every employee — without manual reconciliation or spreadsheet errors eating into your HR team\'s day.',
  },
  {
    num: '05',
    title: 'Employee Lifecycle Management',
    desc: 'Keep complete records of every stage an employee goes through — onboarding, promotions, internal transfers, skill mapping, and separation. HR stays organized and compliant without chasing paperwork across departments.',
  },
];
---

<LeadLayout
  title="Limendo mERP — Your Entire HR. One System."
  description="From hiring to payroll — Limendo mERP powered by Frappe HR handles every part of your workforce in one place."
>

  {/* ================================================================
      HERO
      ================================================================ */}
  <section class="elm-hero">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-16 items-center">

        <div class="w-full lg:w-1/2">
          <span class="label-chip">LIMENDO mERP</span>

